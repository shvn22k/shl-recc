# ── Primary LLM ────────────────────────────────────────────────────────────
# Google Gemini API key — get one at https://aistudio.google.com/
# Used when LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here

# ── Fallback LLM ───────────────────────────────────────────────────────────
# OpenAI API key — get one at https://platform.openai.com/
# Used when LLM_PROVIDER=openai (recommended for deployment)
OPENAI_API_KEY=your_openai_api_key_here

# ── LLM Configuration ──────────────────────────────────────────────────────
# Which provider to use as primary: gemini | openai
# openai is recommended for deployment — more consistent latency
LLM_PROVIDER=openai

# Model names — change only if you want to use a different variant
GEMINI_MODEL=gemini-2.5-flash
OPENAI_MODEL=gpt-4o-mini

# ── Embeddings ─────────────────────────────────────────────────────────────
# Local sentence-transformers model — no API key needed
# Downloaded automatically on first run (~80MB)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Data Paths ─────────────────────────────────────────────────────────────
# Paths are relative to the project root
# These files are committed to the repo — no scraping needed to run locally
CATALOG_PATH=data/catalog.json
INDEX_PATH=data/vector_index

# ── Application Settings ───────────────────────────────────────────────────
# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Maximum conversation turns before forcing end_of_conversation=true
# Must match SHL evaluator expectation (8)
MAX_TURNS=8

# Maximum recommendations per response (hard limit: 10)
MAX_RECOMMENDATIONS=10

# Per-request timeout budget in seconds (hard limit: 30s)
# Set to 25 to leave 5s buffer for network overhead
REQUEST_TIMEOUT_SECONDS=25
